# ============================================================
# Lifestar Ambulance Scheduling System — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values below.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   nano .env   (or your preferred editor)
# ============================================================

# ─── SERVER ────────────────────────────────────────────────
NODE_ENV=development          # production | development
PORT=8061                     # HTTP port to listen on

# ─── SECURITY (REQUIRED IN PRODUCTION) ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_string_at_least_64_characters
COOKIE_SECRET=CHANGE_ME_another_long_random_string_different_from_JWT_SECRET

# Optional JWT tuning
JWT_EXPIRES_IN=8h             # access token lifetime
JWT_REFRESH_EXPIRES_IN=7d     # refresh token lifetime

# ─── ALLOWED ORIGINS (production only) ──────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://lifestar-ambulance.com

# ─── OPTIONAL INTEGRATIONS ──────────────────────────────────
# Twilio (SMS notifications for shift reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (email notifications)
SENDGRID_API_KEY=

# Groq (AI assistant features)
GROQ_API_KEY=
